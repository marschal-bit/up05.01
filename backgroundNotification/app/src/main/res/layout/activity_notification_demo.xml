<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Уведомления в Android"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <!-- Основные уведомления -->
    <Button
        android:id="@+id/simple_notification_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Простое уведомление"/>

    <Button
        android:id="@+id/action_notification_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Уведомление с действиями"/>

    <Button
        android:id="@+id/progress_notification_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Уведомление с прогрессом"/>

    <Button
        android:id="@+id/big_text_notification_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Уведомление с большим текстом"/>

    <!-- ЗАДАНИЕ 1: Уведомление с изображением -->
    <Button
        android:id="@+id/big_picture_notification_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ЗАДАНИЕ 1: BigPictureStyle"
        android:backgroundTint="@android:color/holo_purple" />

    <!-- Разделитель -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray"
        android:layout_marginVertical="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Дополнительные задания"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- ЗАДАНИЕ 3: Группировка уведомлений -->
    <Button
        android:id="@+id/group_notification_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ЗАДАНИЕ 3: Группировка уведомлений"
        android:backgroundTint="@android:color/holo_orange_dark" />

    <Button
        android:id="@+id/cancel_notification_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Отменить уведомление"
        android:backgroundTint="@android:color/holo_red_dark" />

</LinearLayout>