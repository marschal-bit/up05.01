<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="110dp">

    <!-- Включаем макет с камерой и названием -->
    <include layout="@layout/view_camera_and_title" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Дата добавления:"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/book_date_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="01.01.2024" />

    <CheckBox
        android:id="@+id/book_readed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Прочитана"
        android:textSize="16sp"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/book_report"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/book_report_text"
        android:drawableLeft="@android:drawable/ic_menu_send"
        android:padding="12dp"
        android:layout_marginTop="16dp" />

    <!-- Кнопка выбора обложки (из галереи) -->
    <Button
        android:id="@+id/book_cover"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Выбрать обложку"
        android:drawableLeft="@android:drawable/ic_menu_gallery"
        android:padding="12dp" />

    <!-- Кнопка открытия в браузере -->
    <Button
        android:id="@+id/book_browser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Открыть книгу в браузере"
        android:drawableLeft="@android:drawable/ic_menu_search"
        android:padding="12dp" />

    <!-- Превью выбранной обложки из галереи -->
    <ImageView
        android:id="@+id/book_cover_preview"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="8dp"
        android:scaleType="centerCrop"
        android:visibility="gone" />

</LinearLayout>