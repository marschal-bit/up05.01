<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <CheckBox
        android:id="@+id/list_item_book_readed_check_box"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:padding="4dp" />

    <TextView
        android:id="@+id/list_item_book_title_text_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toLeftOf="@id/list_item_book_readed_check_box"
        android:textStyle="bold"
        android:padding="4dp"
        android:textSize="16sp"
        tools:text="Название книги" />

    <TextView
        android:id="@+id/list_item_book_date_text_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toLeftOf="@id/list_item_book_readed_check_box"
        android:layout_below="@id/list_item_book_title_text_view"
        android:padding="4dp"
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        tools:text="Дата" />

</RelativeLayout>