<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="ru.goloskokov.bookdepository">

    <!-- Разрешение для чтения изображений из галереи -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- Разрешение для камеры -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Объявляем использование камеры (обязательно для запуска на устройствах с камерой) -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:name="ru.goloskokov.bookdepository.BookListActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="ru.goloskokov.bookdepository.BookActivity"
            android:exported="false" />

        <activity
            android:name="ru.goloskokov.bookdepository.BookPagerActivity"
            android:parentActivityName="ru.goloskokov.bookdepository.BookListActivity" />

        <!-- FileProvider для работы с камерой на Android 7.0+ -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="ru.goloskokov.bookdepository.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>

    </application>

</manifest>